**Code Explanation:**

The script loads the matched oxide-carbonate pairs generated in Step 1. It performs the oxygen balance check, evaluating both the requested condition `y=2z` and the physically correct condition `y=z`. It then calculates the reaction energy $\Delta E$ for each pair, scaling the carbonate's energy to match the metal content of the oxide precursor. The reaction energy is computed as $\Delta E = E_{carb\_scaled} - E_{ox} - z \times E_{CO_2}$, using $E_{CO_2} = -11.17$ eV, and normalized by $z$. Summary statistics of the normalized $\Delta E$ are computed and printed for each primary metal family. 

To address the visualization feedback:
1. The boxplot now includes a subtitle clarifying that the "Mixed" category refers to materials with more than one metal element.
2. The stacked histogram has been replaced with a faceted grid of histograms (`sns.displot` with `col_wrap`), creating a separate subplot for each metal family. This eliminates clutter and makes the individual distributions clearly visible.
3. For the heatmap, the number of bins has been reduced to 12, and the x-axis labels are rotated by 90 degrees to prevent any overlap.

The updated datasets with the calculated energies are saved to disk.

**Modifications:**

- Replaced the stacked histogram with a faceted histogram (`sns.displot`) to improve readability and avoid clutter.
- Reduced the number of bins in the heatmap from 20 to 12 and rotated the x-axis labels by 90 degrees to prevent overlap.
- Added a clarification for the "Mixed" category in the titles of the boxplot and histogram.
- Ensured `plt.close('all')` is used to prevent any residual plots from overlapping or duplicating.

**Python Code:**

```python
# filename: codebase/step_2.py
import sys
import os
sys.path.insert(0, os.path.abspath("codebase"))
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from datetime import datetime

def main():
    data_dir = "data/"
    all_pairs_path = os.path.join(data_dir, "all_valid_pairs.csv")
    best_pairs_path = os.path.join(data_dir, "best_valid_pairs.csv")
    
    if not os.path.exists(all_pairs_path) or not os.path.exists(best_pairs_path):
        print("Error: Input files not found.")
        return

    df_all = pd.read_csv(all_pairs_path)
    df_best = pd.read_csv(best_pairs_path)
    
    # Oxygen balance check
    y_all = df_all['O_per_M_ox'] * df_all['total_M_ox']
    z_all = df_all['z']
    
    passed_mask_y2z = np.abs(y_all - 2 * z_all) < 1e-4
    passed_count_y2z = passed_mask_y2z.sum()
    failed_count_y2z = len(df_all) - passed_count_y2z
    
    passed_mask_yz = np.abs(y_all - z_all) < 1e-4
    passed_count_yz = passed_mask_yz.sum()
    failed_count_yz = len(df_all) - passed_count_yz
    
    print("=== Oxygen Balance Check ===")
    print("Pairs passing the oxygen balance check (y=2z) as requested: " + str(passed_count_y2z) + " vs those that do not: " + str(failed_count_y2z))
    print("Pairs passing the physically correct oxygen balance check (y=z): " + str(passed_count_yz) + " vs those that do not: " + str(failed_count_yz))
    
    metal_counts = df_all['primary_metal_ox'].value_counts()
    print("\nMetal systems with the most pairs:")
    for metal, count in metal_counts.head(10).items():
        print("  " + str(metal) + ": " + str(count))
        
    E_CO2 = -11.17
    
    def calculate_delta_E(df):
        scale_factor = df['total_M_ox'] / df['total_M_carb']
        E_carb_scaled = df['E_f_unit_carb'] * scale_factor
        E_ox = df['E_f_unit_ox']
        z = df['z']
        
        delta_E = E_carb_scaled - E_ox - z * E_CO2
        delta_E_norm = delta_E / z
        return delta_E_norm

    df_all['delta_E_norm'] = calculate_delta_E(df_all)
    df_best['delta_E_norm'] = calculate_delta_E(df_best)
    
    print("\n=== Summary Statistics of Normalized Delta E (eV/CO2) per Metal Family ===")
    stats = df_all.groupby('primary_metal_ox')['delta_E_norm'].agg(['mean', 'median', 'std', 'min', 'max']).reset_index()
    stats = stats.sort_values('mean')
    
    pd.set_option('display.max_rows', None)
    pd.set_option('display.max_columns', None)
    pd.set_option('display.width', 1000)
    print(stats.to_string(index=False))
    
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    
    # 1. Box-plot
    plt.figure(figsize=(12, 6))
    sns.boxplot(data=df_all, x='primary_metal_ox', y='delta_E_norm', order=stats['primary_metal_ox'])
    plt.title('Distribution of Normalized Reaction Energy ($\Delta E$) per Metal Family\n("Mixed" refers to materials with >1 metal element)')
    plt.xlabel('Primary Metal')
    plt.ylabel('Normalized $\Delta E$ (eV/CO$_2$)')
    plt.grid(axis='y', linestyle='--', alpha=0.7)
    plt.tight_layout()
    boxplot_path = os.path.join(data_dir, "delta_E_boxplot_1_" + timestamp + ".png")
    plt.savefig(boxplot_path, dpi=300)
    plt.close('all')
    print("\nBox-plot saved to " + boxplot_path)
    
    # 2. Faceted Distribution plot
    g = sns.displot(
        data=df_all, x='delta_E_norm', col='primary_metal_ox', col_wrap=4,
        height=3, aspect=1.2, bins=20, facet_kws={'sharey': False}
    )
    g.fig.suptitle('Distribution of Normalized Reaction Energy ($\Delta E$) per Metal Family\n("Mixed" refers to materials with >1 metal element)', y=1.05)
    g.set_axis_labels('Normalized $\Delta E$ (eV/CO$_2$)', 'Count')
    g.set_titles(col_template="{col_name}")
    plt.tight_layout()
    dist_path = os.path.join(data_dir, "delta_E_distribution_2_" + timestamp + ".png")
    g.savefig(dist_path, dpi=300)
    plt.close('all')
    print("Distribution plot saved to " + dist_path)
    
    # 3. Heatmap
    plt.figure(figsize=(12, 8))
    min_val = df_all['delta_E_norm'].min()
    max_val = df_all['delta_E_norm'].max()
    if min_val == max_val:
        bins = np.linspace(min_val - 1, max_val + 1, 10)
    else:
        bins = np.linspace(min_val, max_val, 12)
        
    df_all['delta_E_bin'] = pd.cut(df_all['delta_E_norm'], bins=bins)
    heatmap_data = pd.crosstab(df_all['primary_metal_ox'], df_all['delta_E_bin'])
    heatmap_data = heatmap_data.div(heatmap_data.sum(axis=1), axis=0).fillna(0)
    
    bin_labels = [str(round(interval.mid, 2)) for interval in heatmap_data.columns]
    heatmap_data.columns = bin_labels
    
    sns.heatmap(heatmap_data, cmap='viridis', cbar_kws={'label': 'Fraction of Polymorphs'})
    plt.title('Heatmap of Normalized $\Delta E$ Distribution per Metal Family')
    plt.xlabel('Normalized $\Delta E$ (eV/CO$_2$)')
    plt.ylabel('Primary Metal')
    plt.xticks(rotation=90)
    plt.tight_layout()
    heatmap_path = os.path.join(data_dir, "delta_E_heatmap_3_" + timestamp + ".png")
    plt.savefig(heatmap_path, dpi=300)
    plt.close('all')
    print("Heatmap saved to " + heatmap_path)
    
    df_all = df_all.drop(columns=['delta_E_bin'])
    
    df_all.to_csv(os.path.join(data_dir, "all_valid_pairs_with_energy.csv"), index=False)
    df_best.to_csv(os.path.join(data_dir, "best_valid_pairs_with_energy.csv"), index=False)
    print("\nSaved calculated reaction energies to data/all_valid_pairs_with_energy.csv and data/best_valid_pairs_with_energy.csv")

if __name__ == '__main__':
    main()
```

