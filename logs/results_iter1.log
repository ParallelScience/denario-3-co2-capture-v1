    parts = metal_key.split('_')
    max_frac = -1
    primary = 'Unknown'
    for part in parts:
        match = re.match(r'([A-Z][a-z]*)(\d*\.?\d*)', part)
        if match:
            el = match.group(1)
            frac_str = match.group(2)
            frac = float(frac_str) if frac_str else 1.0
            if frac > max_frac:
                max_frac = frac
                primary = el
    return primary

